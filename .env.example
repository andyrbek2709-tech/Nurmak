# Telegram Bot Token (from @BotFather)
BOT_TOKEN=

# OpenAI API Key (from https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Supabase (from https://supabase.com/dashboard → Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Manager Telegram Chat ID (send /start to @userinfobot to get your ID)
MANAGER_CHAT_ID=

# Railway domain (assigned after deploy)
WEBHOOK_DOMAIN=https://your-app.up.railway.app

# Port (Railway sets this automatically)
PORT=3000